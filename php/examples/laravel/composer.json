{
    "name": "laravel/nativebpm-example",
    "description": "Laravel integration example with NativeBPM PHP Client SDK",
    "type": "project",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0 || ^11.0",
        "nativebpm/client": "1.0.0"
    },
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "nativebpm/client",
                "version": "1.0.0",
                "source": {
                    "url": "https://gitlab.com/nativebpm/platform.git",
                    "type": "git",
                    "reference": "sdk/php/v1.0.0"
                },
                "autoload": {
                    "psr-4": {
                        "NativeBPM\\Client\\": "sdk/php/lib/"
                    }
                },
                "require": {
                    "php": "^8.1",
                    "ext-curl": "*",
                    "ext-json": "*",
                    "ext-mbstring": "*",
                    "guzzlehttp/guzzle": "^7.3",
                    "guzzlehttp/psr7": "^1.7 || ^2.0"
                }
            }
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    }
}
